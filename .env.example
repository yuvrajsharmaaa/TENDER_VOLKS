# App Configuration
APP_NAME="VolksEnergies Tender OCR"
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Postgres Database Configuration
# Internal container URL: postgresql://<user>:<password>@postgres:5432/<db_name>
# Host URL: postgresql://<user>:<password>@localhost:5432/<db_name>
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/tender_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tender_db

# Redis Configuration
# Internal container URL: redis://redis:6379/0
# Host URL: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# MinIO Configuration
# Internal container URL: minio:9000
# Host URL: localhost:9000
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=tender-raw
MINIO_BUCKET_PROCESSED=tender-processed

# Gemini API Key (Optional for basic OCR, required for intelligent parsing)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS Configuration (comma-separated list of origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# SMTP Configuration
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=your_smtp_sender_email_here
